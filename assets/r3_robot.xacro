<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="pi2" value="${pi * 0.5}" />

    <xacro:property name="width" value="0.01" />
    <xacro:property name="l1" value="0.15" />
    <xacro:property name="l2" value="0.25" />
    <xacro:property name="l3" value="0.25" />

    <xacro:property name="m1" value="1" />
    <xacro:property name="m2" value="1" />
    <xacro:property name="m3" value="1" />

    <!-- Wrap the entire robot definition in a macro -->
    <xacro:macro name="r3_robot" params="prefix xyz rpy">
        <link name="${prefix}_base"/>
        
        <link name="${prefix}_link1">
            <visual>
                <origin xyz="0 0 ${l1 * 0.5}" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="${width}" length="${l1}"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 ${l1 * 0.5}" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="${width}" length="${l1}"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 ${l1 * 0.5}" rpy="0 0 0"/>
                <mass value="${m1}" />
                <inertia ixx="${1.0/12.0 * m1 * (3 * width*width + l1*l1)}"
                        ixy="0.0" ixz="0.0"
                        iyy="${1.0/12.0 * m1 * (3 * width*width + l1*l1)}" 
                        iyz="0.0"
                        izz="${1.0/2.0 * m1 * l1*l1}" />
            </inertial>
        </link>
        <link name="${prefix}_link2">
            <visual>
                <origin xyz="0 0 ${l2 * 0.5}" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="${width}" length="${l2}"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 ${l2 * 0.5}" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="${width}" length="${l2}"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 ${l2 * 0.5}" rpy="0 0 0"/>
                <mass value="${m2}" />
                <inertia ixx="${1.0/12.0 * m2 * (3 * width*width + l2*l2)}"
                        ixy="0.0" ixz="0.0"
                        iyy="${1.0/12.0 * m2 * (3 * width*width + l2*l2)}" 
                        iyz="0.0"
                        izz="${1.0/2.0 * m2 * l2*l2}" />
            </inertial>
        </link>
        <link name="${prefix}_link3">
            <visual>
                <origin xyz="0 0 ${l3 * 0.5}" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="${width}" length="${l3}"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 ${l3 * 0.5}" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="${width}" length="${l3}"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 ${l3 * 0.5}" rpy="0 0 0"/>
                <mass value="${m3}" />
                <inertia ixx="${1.0/12.0 * m3 * (3 * width*width + l3*l3)}"
                        ixy="0.0" ixz="0.0"
                        iyy="${1.0/12.0 * m3 * (3 * width*width + l3*l3)}" 
                        iyz="0.0"
                        izz="${1.0/2.0 * m3 * l3*l3}" />
            </inertial>
        </link>

        <joint name="${prefix}_joint1" type="revolute">
            <parent link="${prefix}_base" />
            <child link="${prefix}_link1" />
            <limit effort="30" velocity="1.0" lower="${0}" upper="${pi}" />
            <origin xyz="${xyz}" rpy="${rpy}" />
            <axis xyz="1 0 0" />
        </joint>
        <joint name="${prefix}_joint2" type="revolute">
            <parent link="${prefix}_link1" />
            <child link="${prefix}_link2" />
            <limit effort="30" velocity="1.0" lower="${0}" upper="${pi}" />
            <origin xyz="0 0 ${l1}" rpy="0 0 0" />
            <axis xyz="1 0 0" />
        </joint>
        <joint name="${prefix}_joint3" type="revolute">
            <parent link="${prefix}_link2" />
            <child link="${prefix}_link3" />
            <limit effort="30" velocity="1.0" lower="${0}" upper="${pi}" />
            <origin xyz="0 0 ${l2}" rpy="0 0 0" />
            <axis xyz="1 0 0" />
        </joint>

    </xacro:macro>    
</robot>