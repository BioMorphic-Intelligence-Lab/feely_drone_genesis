<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="gripper">

    <!-- Include the robot macro -->
    <xacro:include filename="r3_robot.xacro"/>
    
    <!-- Base Properties -->
    <xacro:property name="m_base" value="1.0" />
    <xacro:property name="base_width" value="0.25" />
    <xacro:property name="depth" value="0.25" />
    <xacro:property name="height" value="0.05" />

    <!-- Create three instances of the robot, rotated to form a gripper -->
    <xacro:r3_robot prefix="arm1" xyz="-${base_width/2} ${depth/2} 0" rpy="${-pi2} 0 0" />
    <xacro:r3_robot prefix="arm2" xyz=" 0.0       -${depth/2} 0" rpy="${-pi2} 0 ${pi}" />
    <xacro:r3_robot prefix="arm3" xyz=" ${base_width/2} ${depth/2} 0" rpy="${-pi2} 0 0" />

    <!-- Optionally, add a base link or other structure to connect the arms -->
    <link name="world"/>
    
    <link name="p1"/>
    <link name="p2"/>
    <link name="p3"/>
    
    <link name="base">
        <visual>
            <geometry>
                <box size="${base_width} ${depth} ${height}"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${base_width} ${depth} ${height}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m_base}" />
            <inertia ixx="${1.0/12.0 * m_base * (height*height + depth*depth)}"
                     ixy="0.0" ixz="0.0"
                     iyy="${1.0/12.0 * m_base * (height*height + base_width*base_width)}" 
                     iyz="0.0"
                     izz="${1.0/12.0 * m_base * (base_width*base_width + depth*depth)}" />
        </inertial>
    </link>

    <joint name="x_pos" type="prismatic">
        <parent link="world" />
        <child link="p1" />
        <axis xyz="1 0 0"/>
        <limit lower="-100" upper="100" effort="100" velocity="100"/>
    </joint>

    <joint name="y_pos" type="prismatic">
        <parent link="p1" />
        <child link="p2" />
        <axis xyz="0 1 0"/>
        <limit lower="-100" upper="100" effort="100" velocity="100"/>
    </joint>

    <joint name="z_pos" type="prismatic">
        <parent link="p2" />
        <child link="p3" />
        <axis xyz="0 0 1"/>
        <limit lower="-100" upper="100" effort="100" velocity="100"/>
    </joint>

    <joint name="base_joint" type="continuous">
        <parent link="p3" />
        <child link="base" />
        <axis xyz="0 0 1"/>
        <dynamics damping="100.0" friction="0.0"/>
    </joint>

    <joint name="arm1_fix" type="fixed">
        <parent link="base" />
        <child link="arm1_base" />
    </joint>
    <joint name="arm2_fix" type="fixed">
        <parent link="base" />
        <child link="arm2_base" />
    </joint>
    <joint name="arm3_fix" type="fixed">
        <parent link="base" />
        <child link="arm3_base" />
    </joint>
</robot>